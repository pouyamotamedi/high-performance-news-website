# Email Service Configuration

# Email service provider (sendgrid or mailgun)
EMAIL_PROVIDER=sendgrid

# Email settings
EMAIL_FROM=noreply@yournewssite.com
EMAIL_FROM_NAME=Your News Site
EMAIL_REPLY_TO=support@yournewssite.com

# Base URL for links in emails
BASE_URL=https://yournewssite.com

# Email service settings
EMAIL_ENABLED=true
EMAIL_RATE_LIMIT=100000  # 100K emails per hour
EMAIL_BATCH_SIZE=1000    # Batch size for bulk sending
EMAIL_MAX_RETRIES=3      # Max retry attempts for failed sends

# SendGrid Configuration
SENDGRID_API_KEY=your_sendgrid_api_key_here
SENDGRID_ENDPOINT=https://api.sendgrid.com/v3/mail/send

# Mailgun Configuration (alternative to SendGrid)
MAILGUN_API_KEY=your_mailgun_api_key_here
MAILGUN_DOMAIN=mg.yournewssite.com
MAILGUN_ENDPOINT=https://api.mailgun.net/v3

# Database Configuration (if not already set)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=news_website
DB_USER=news_user
DB_PASSWORD=your_db_password
DB_SSL_MODE=disable

# Redis/DragonflyDB Configuration (for caching)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Queue Configuration
QUEUE_REDIS_HOST=localhost
QUEUE_REDIS_PORT=6379
QUEUE_REDIS_PASSWORD=
QUEUE_REDIS_DB=1

# Webhook Security (optional)
WEBHOOK_SECRET=your_webhook_secret_for_verification

# GDPR Compliance Settings
GDPR_ENABLED=true
DATA_RETENTION_DAYS=365  # How long to keep email data

# Email Template Settings
DEFAULT_LANGUAGE=en
SUPPORTED_LANGUAGES=en,fa,ar

# Performance Settings
EMAIL_WORKER_COUNT=4     # Number of email processing workers
EMAIL_QUEUE_SIZE=10000   # Maximum queue size
EMAIL_TIMEOUT=30         # Email sending timeout in seconds

# Monitoring and Logging
LOG_LEVEL=info
METRICS_ENABLED=true
HEALTH_CHECK_ENABLED=true

# Development Settings (for testing)
EMAIL_DEBUG=false        # Enable debug logging
EMAIL_DRY_RUN=false     # Don't actually send emails (for testing)