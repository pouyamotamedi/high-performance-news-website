# Server Configuration
NEWS_SERVER_HOST=0.0.0.0
NEWS_SERVER_PORT=8080
NEWS_SERVER_MODE=debug

# Database Configuration
NEWS_DATABASE_HOST=localhost
NEWS_DATABASE_PORT=5432
NEWS_DATABASE_USER=postgres
NEWS_DATABASE_PASSWORD=postgres
NEWS_DATABASE_DBNAME=news_website
NEWS_DATABASE_SSLMODE=disable
NEWS_DATABASE_MAX_CONNS=150
NEWS_DATABASE_MIN_CONNS=40

# Cache Configuration (DragonflyDB)
NEWS_CACHE_HOST=localhost
NEWS_CACHE_PORT=6379
NEWS_CACHE_PASSWORD=
NEWS_CACHE_DB=0

# MeiliSearch Configuration
NEWS_SEARCH_ENABLED=true
NEWS_SEARCH_MEILISEARCH_URL=http://localhost:7700
NEWS_SEARCH_MEILISEARCH_API_KEY=your-meilisearch-master-key
NEWS_SEARCH_INDEX_NAME=articles

# Application Configuration
NEWS_APP_NAME="High Performance News Website"
NEWS_APP_VERSION=1.0.0
NEWS_APP_ENVIRONMENT=development
NEWS_APP_LOG_LEVEL=info
NEWS_APP_BASE_URL=https://cryptonlisys.com

# JWT Secret (generate a secure random string for production)
NEWS_JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# External API Keys (for future integrations)
# NEWS_OPENAI_API_KEY=
# NEWS_SENDGRID_API_KEY=
# NEWS_CLOUDFLARE_API_KEY=