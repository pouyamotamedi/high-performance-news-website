// HandleWebSocket handles WebSocket connections for real-time monitoring
func (h *TestMonitoringHandlers) HandleWebSocket(c *gin.Context) {
	dashboard := h.monitoringIntegration.GetDashboard()
	dashboard.RegisterRoutes(c.Engine)
}

// Helper functions

func parseIntQuery(c *gin.Context, key string, defaultValue int) int {
	if value := c.Query(key); value != "" {
		if parsed, err := strconv.Atoi(value); err == nil {
			return parsed
		}
	}
	return defaultValue
}