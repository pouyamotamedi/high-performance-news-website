package testing

import (
	"context"
	"fmt"
	"math/rand"
	"sync"
	"time"
)

// ResilienceValidator provides comprehensive resilience validation capabilities
type ResilienceValidator struct {
	faultInjector    *EnhancedFaultInjector
	systemMonitor    *SystemMonitor
	recoveryTracker  *RecoveryTracker
	degradationChecker *DegradationChecker
	stabilityAnalyzer *StabilityAnalyzer
}

// NewResilienceValidator creates a new resilience validator
func NewResilienceValidator() *ResilienceValidator {
	return &ResilienceValidator{
		faultInjector:      NewEnhancedFaultInjector(),
		systemMonitor:      NewSystemMonitor(),
		recoveryTracker:    NewRecoveryTracker(),
		degradationChecker: NewDegradationChecker(),
		stabilityAnalyzer:  NewStabilityAnalyzer(),
	}
}

// ResilienceTestResult represents the result of a resilience validation test
type ResilienceTestResult struct {
	TestName            string                 `json:"test_name"`
	StartTime           time.Time              `json:"start_time"`
	EndTime             time.Time              `json:"end_time"`
	Duration            time.Duration          `json:"duration"`
	Success             bool                   `json:"success"`
	RecoveryTime        time.Duration          `json:"recovery_time"`
	GracefulDegradation bool                   `json:"graceful_degradation"`
	CascadeFailures     []CascadeFailure       `json:"cascade_failures"`
	SystemStability     SystemStabilityMetrics `json:"system_stability"`
	Errors              []string               `json:"errors"`
	Recommendations     []string               `json:"recommendations"`
}



// SystemStabilityMetrics tracks system stability during chaos testing
type SystemStabilityMetrics struct {
	AvailabilityPercent    float64           `json:"availability_percent"`
	ResponseTimeP95        time.Duration     `json:"response_time_p95"`
	ErrorRate              float64           `json:"error_rate"`
	ThroughputDegradation  float64           `json:"throughput_degradation"`
	ResourceUtilization    map[string]float64 `json:"resource_utilization"`
}

// ValidateSystemRecoveryTime tests system recovery time under various failure conditions
func (rv *ResilienceValidator) ValidateSystemRecoveryTime(ctx context.Context, maxRecoveryTime time.Duration) (*ResilienceTestResult, error) {
	result := &ResilienceTestResult{
		TestName:  "System Recovery Time Validation",
		StartTime: time.Now(),
		Errors:    make([]string, 0),
		Recommendations: make([]string, 0),
	}

	// Test database failure recovery
	dbRecoveryResult, err := rv.testDatabaseRecovery(ctx, maxRecoveryTime)
	if err != nil {
		result.Errors = append(result.Errors, fmt.Sprintf("Database recovery test failed: %v", err))
	} else {
		if dbRecoveryResult.RecoveryTime > maxRecoveryTime {
			result.Errors = append(result.Errors, fmt.Sprintf("Database recovery time %v exceeds maximum %v", dbRecoveryResult.RecoveryTime, maxRecoveryTime))
			result.Recommendations = append(result.Recommendations, "Consider implementing database connection pooling with faster failover")
		}
	}

	// Test cache failure recovery
	cacheRecoveryResult, err := rv.testCacheRecovery(ctx, maxRecoveryTime)
	if err != nil {
		result.Errors = append(result.Errors, fmt.Sprintf("Cache recovery test failed: %v", err))
	} else {
		if cacheRecoveryResult.RecoveryTime > maxRecoveryTime {
			result.Errors = append(result.Errors, fmt.Sprintf("Cache recovery time %v exceeds maximum %v", cacheRecoveryResult.RecoveryTime, maxRecoveryTime))
			result.Recommendations = append(result.Recommendations, "Implement cache circuit breaker with faster fallback to database")
		}
	}

	// Test network partition recovery
	networkRecoveryResult, err := rv.testNetworkRecovery(ctx, maxRecoveryTime)
	if err != nil {
		result.Errors = append(result.Errors, fmt.Sprintf("Network recovery test failed: %v", err))
	} else {
		if networkRecoveryResult.RecoveryTime > maxRecoveryTime {
			result.Errors = append(result.Errors, fmt.Sprintf("Network recovery time %v exceeds maximum %v", networkRecoveryResult.RecoveryTime, maxRecoveryTime))
			result.Recommendations = append(result.Recommendations, "Implement retry mechanisms with exponential backoff for external services")
		}
	}

	// Calculate overall recovery time
	maxObservedRecovery := time.Duration(0)
	if dbRecoveryResult != nil && dbRecoveryResult.RecoveryTime > maxObservedRecovery {
		maxObservedRecovery = dbRecoveryResult.RecoveryTime
	}
	if cacheRecoveryResult != nil && cacheRecoveryResult.RecoveryTime > maxObservedRecovery {
		maxObservedRecovery = cacheRecoveryResult.RecoveryTime
	}
	if networkRecoveryResult != nil && networkRecoveryResult.RecoveryTime > maxObservedRecovery {
		maxObservedRecovery = networkRecoveryResult.RecoveryTime
	}

	result.RecoveryTime = maxObservedRecovery
	result.EndTime = time.Now()
	result.Duration = result.EndTime.Sub(result.StartTime)
	result.Success = len(result.Errors) == 0

	return result, nil
}

// ValidateGracefulDegradation tests system's ability to degrade gracefully under failure
func (rv *ResilienceValidator) ValidateGracefulDegradation(ctx context.Context) (*ResilienceTestResult, error) {
	result := &ResilienceTestResult{
		TestName:  "Graceful Degradation Validation",
		StartTime: time.Now(),
		Errors:    make([]string, 0),
		Recommendations: make([]string, 0),
	}

	// Test cache failure degradation
	cacheResult, err := rv.testCacheDegradation(ctx)
	if err != nil {
		result.Errors = append(result.Errors, fmt.Sprintf("Cache degradation test failed: %v", err))
	} else {
		result.GracefulDegradation = cacheResult.GracefulDegradation
		if !cacheResult.GracefulDegradation {
			result.Recommendations = append(result.Recommendations, "Implement graceful cache fallback to database queries")
		}
	}

	// Test search service degradation
	searchResult, err := rv.testSearchDegradation(ctx)
	if err != nil {
		result.Errors = append(result.Errors, fmt.Sprintf("Search degradation test failed: %v", err))
	} else {
		if !searchResult.GracefulDegradation {
			result.GracefulDegradation = false
			result.Recommendations = append(result.Recommendations, "Implement search fallback to database queries when MeiliSearch is unavailable")
		}
	}

	// Test external API degradation
	apiResult, err := rv.testExternalAPIDegradation(ctx)
	if err != nil {
		result.Errors = append(result.Errors, fmt.Sprintf("External API degradation test failed: %v", err))
	} else {
		if !apiResult.GracefulDegradation {
			result.GracefulDegradation = false
			result.Recommendations = append(result.Recommendations, "Implement circuit breakers for external API calls")
		}
	}

	// Test memory pressure degradation
	memoryResult, err := rv.testMemoryPressureDegradation(ctx)
	if err != nil {
		result.Errors = append(result.Errors, fmt.Sprintf("Memory pressure degradation test failed: %v", err))
	} else {
		if !memoryResult.GracefulDegradation {
			result.GracefulDegradation = false
			result.Recommendations = append(result.Recommendations, "Implement memory-aware job queue throttling")
		}
	}

	result.EndTime = time.Now()
	result.Duration = result.EndTime.Sub(result.StartTime)
	result.Success = len(result.Errors) == 0 && result.GracefulDegradation

	return result, nil
}

// ValidateCascadeFailurePrevention tests system's ability to prevent cascade failures
func (rv *ResilienceValidator) ValidateCascadeFailurePrevention(ctx context.Context) (*ResilienceTestResult, error) {
	result := &ResilienceTestResult{
		TestName:        "Cascade Failure Prevention Validation",
		StartTime:       time.Now(),
		CascadeFailures: make([]CascadeFailure, 0),
		Errors:          make([]string, 0),
		Recommendations: make([]string, 0),
	}

	// Start monitoring for cascade failures
	cascadeMonitor := rv.startCascadeFailureMonitoring(ctx)
	defer cascadeMonitor.Stop()

	// Inject primary failure (database)
	_, err := rv.faultInjector.InjectDatabaseFailure(ctx, 0.8, 30*time.Second)
	if err != nil {
		result.Errors = append(result.Errors, fmt.Sprintf("Failed to inject database failure: %v", err))
		return result, err
	}

	// Monitor for 60 seconds to detect cascade failures
	monitoringDuration := 60 * time.Second
	monitoringEnd := time.After(monitoringDuration)
	ticker := time.NewTicker(5 * time.Second)
	defer ticker.Stop()

	for {
		select {
		case <-ctx.Done():
			result.Errors = append(result.Errors, "Context cancelled during cascade monitoring")
			return result, ctx.Err()
		case <-monitoringEnd:
			goto MonitoringComplete
		case <-ticker.C:
			// Check for new cascade failures
			newFailures := cascadeMonitor.GetNewFailures()
			for _, failure := range newFailures {
				result.CascadeFailures = append(result.CascadeFailures, failure)
			}
		}
	}

MonitoringComplete:
	// Analyze cascade failures
	if len(result.CascadeFailures) > 0 {
		result.Success = false
		result.Recommendations = append(result.Recommendations, "Implement circuit breakers to prevent cascade failures")
		result.Recommendations = append(result.Recommendations, "Add bulkhead isolation between system components")
		
		for _, failure := range result.CascadeFailures {
			result.Errors = append(result.Errors, fmt.Sprintf("Cascade failure detected in %s: %s", failure.Component, failure.Impact))
		}
	} else {
		result.Success = true
	}

	result.EndTime = time.Now()
	result.Duration = result.EndTime.Sub(result.StartTime)

	return result, nil
}

// ValidateSystemStabilityUnderChaos tests overall system stability under chaotic conditions
func (rv *ResilienceValidator) ValidateSystemStabilityUnderChaos(ctx context.Context, duration time.Duration) (*ResilienceTestResult, error) {
	result := &ResilienceTestResult{
		TestName:  "System Stability Under Chaos Validation",
		StartTime: time.Now(),
		Errors:    make([]string, 0),
		Recommendations: make([]string, 0),
	}

	// Start system monitoring
	stabilityMonitor := rv.systemMonitor.StartStabilityMonitoring(ctx)
	defer stabilityMonitor.Stop()

	// Create chaos scenario with multiple concurrent faults
	chaosRunner := NewChaosTestRunner()
	
	// Define chaos scenario
	scenario := ChaosTestScenario{
		Name:        "Multi-Fault Chaos Test",
		Description: "Tests system stability under multiple concurrent faults",
		Duration:    duration,
		Faults: []FaultConfig{
			{
				Type: FaultTypeDatabase,
				Parameters: map[string]interface{}{
					"failure_rate": 0.3,
				},
				StartDelay: 0,
				Duration:   duration,
			},
			{
				Type: FaultTypeCache,
				Parameters: map[string]interface{}{
					"failure_type": "timeout",
				},
				StartDelay: 10 * time.Second,
				Duration:   duration - 10*time.Second,
			},
			{
				Type: FaultTypeNetwork,
				Parameters: map[string]interface{}{
					"latency_ms":   200,
					"packet_loss": 0.1,
				},
				StartDelay: 20 * time.Second,
				Duration:   duration - 20*time.Second,
			},
			{
				Type: FaultTypeMemory,
				Parameters: map[string]interface{}{
					"pressure_level": 0.7,
				},
				StartDelay: 30 * time.Second,
				Duration:   duration - 30*time.Second,
			},
		},
		Validation: func(faultResult *FaultResult) bool {
			return faultResult.SystemRecovered && faultResult.GracefulDegradation
		},
	}

	chaosRunner.AddScenario(scenario)

	// Execute chaos scenario
	_, err := chaosRunner.RunScenario(ctx, scenario.Name)
	if err != nil {
		result.Errors = append(result.Errors, fmt.Sprintf("Chaos scenario execution failed: %v", err))
		return result, err
	}

	// Collect stability metrics
	stabilityMetrics := stabilityMonitor.GetMetrics()
	result.SystemStability = SystemStabilityMetrics{
		AvailabilityPercent:   stabilityMetrics.AvailabilityPercent,
		ResponseTimeP95:       stabilityMetrics.ResponseTimeP95,
		ErrorRate:             stabilityMetrics.ErrorRate,
		ThroughputDegradation: stabilityMetrics.ThroughputDegradation,
		ResourceUtilization:   stabilityMetrics.ResourceUtilization,
	}

	// Validate stability thresholds
	if stabilityMetrics.AvailabilityPercent < 95.0 {
		result.Errors = append(result.Errors, fmt.Sprintf("Availability %.2f%% below threshold 95%%", stabilityMetrics.AvailabilityPercent))
		result.Recommendations = append(result.Recommendations, "Improve system resilience to maintain higher availability under chaos")
	}

	if stabilityMetrics.ErrorRate > 0.05 {
		result.Errors = append(result.Errors, fmt.Sprintf("Error rate %.2f%% above threshold 5%%", stabilityMetrics.ErrorRate*100))
		result.Recommendations = append(result.Recommendations, "Implement better error handling and retry mechanisms")
	}

	if stabilityMetrics.ResponseTimeP95 > 2*time.Second {
		result.Errors = append(result.Errors, fmt.Sprintf("P95 response time %v above threshold 2s", stabilityMetrics.ResponseTimeP95))
		result.Recommendations = append(result.Recommendations, "Optimize performance under failure conditions")
	}

	if stabilityMetrics.ThroughputDegradation > 0.5 {
		result.Errors = append(result.Errors, fmt.Sprintf("Throughput degradation %.2f%% above threshold 50%%", stabilityMetrics.ThroughputDegradation*100))
		result.Recommendations = append(result.Recommendations, "Implement load shedding to maintain throughput under stress")
	}

	result.Success = len(result.Errors) == 0
	result.EndTime = time.Now()
	result.Duration = result.EndTime.Sub(result.StartTime)

	return result, nil
}

// testDatabaseRecovery tests database failure recovery
func (rv *ResilienceValidator) testDatabaseRecovery(ctx context.Context, maxRecoveryTime time.Duration) (*FaultResult, error) {
	return rv.faultInjector.InjectDatabaseFailure(ctx, 1.0, 10*time.Second)
}

