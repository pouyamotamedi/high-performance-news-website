func (rv *ResilienceValidator) testNetworkRecovery(ctx context.Context, maxRecoveryTime time.Duration) (*FaultResult, error) {
	return rv.faultInjector.InjectNetworkPartition(ctx, 1000, 0.5, 10*time.Second)
}

