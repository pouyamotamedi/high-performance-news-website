// registerActiveFault registers an active fault
func (fi *FaultInjector) registerActiveFault(fault *ActiveFault) {
	fi.faultMutex.Lock()
	defer fi.faultMutex.Unlock()
	fi.activeFaults[fault.ID] = fault
}

// stopFault stops an active fault
func (fi *FaultInjector) stopFault(faultID string) error {
	fi.faultMutex.Lock()
	defer fi.faultMutex.Unlock()

	fault, exists := fi.activeFaults[faultID]
	if !exists {
		return fmt.Errorf("fault %s not found", faultID)
	}

	if fault.StopFunc != nil {
		if err := fault.StopFunc(); err != nil {
			return fmt.Errorf("failed to stop fault %s: %w", faultID, err)
		}
	}

	delete(fi.activeFaults, faultID)
	return nil
}

// monitorFaultImpact monitors system behavior during fault injection
func (fi *FaultInjector) monitorFaultImpact(ctx context.Context, fault *ActiveFault) *FaultResult {
	result := &FaultResult{
		FaultID:          fault.ID,
		Type:             fault.Type,
		Duration:         fault.Duration,
		ErrorsObserved:   make([]string, 0),
		MetricsCollected: make(map[string]float64),
		Parameters:       fault.Parameters,
	}

	startTime := time.Now()
	timeout := time.After(fault.Duration)
	ticker := time.NewTicker(1 * time.Second)
	defer ticker.Stop()

	var recoveryStartTime time.Time
	systemHealthy := true

	for {
		select {
		case <-ctx.Done():
			result.ErrorsObserved = append(result.ErrorsObserved, "Context cancelled during monitoring")
			return result
		case <-timeout:
			result.Duration = time.Since(startTime)
			if !systemHealthy && !recoveryStartTime.IsZero() {
				result.RecoveryTime = time.Since(recoveryStartTime)
				result.SystemRecovered = true
			}
			return result
		case <-ticker.C:
			// Check system health
			healthy := fi.checkSystemHealth(ctx)
			
			if systemHealthy && !healthy {
				// System just became unhealthy
				systemHealthy = false
				result.ErrorsObserved = append(result.ErrorsObserved, "System became unhealthy")
			} else if !systemHealthy && healthy {
				// System recovered
				if recoveryStartTime.IsZero() {
					recoveryStartTime = time.Now()
				}
				systemHealthy = true
				result.SystemRecovered = true
				result.GracefulDegradation = true
			}

			// Collect metrics
			fi.collectMetrics(result)
		}
	}
}

// checkSystemHealth performs basic system health checks
func (fi *FaultInjector) checkSystemHealth(ctx context.Context) bool {
	// This is a simplified health check - in a real implementation,
	// you would check actual system endpoints and services
	
	// Check if we can make basic operations
	healthChecks := []func() bool{
		fi.checkDatabaseHealth,
		fi.checkCacheHealth,
		fi.checkMemoryHealth,
		fi.checkDiskHealth,
	}

	healthyCount := 0
	for _, check := range healthChecks {
		if check() {
			healthyCount++
		}
	}

	// System is healthy if at least 75% of checks pass
	return float64(healthyCount)/float64(len(healthChecks)) >= 0.75
}

// checkDatabaseHealth checks database connectivity
func (fi *FaultInjector) checkDatabaseHealth() bool {
	// Simplified database health check
	return !fi.databaseInjector.IsFailureActive()
}

// checkCacheHealth checks cache service health
func (fi *FaultInjector) checkCacheHealth() bool {
	// Simplified cache health check
	return !fi.cacheInjector.IsFailureActive()
}

// checkMemoryHealth checks memory usage
func (fi *FaultInjector) checkMemoryHealth() bool {
	// Simplified memory health check
	return !fi.resourceInjector.IsMemoryPressureActive()
}

// checkDiskHealth checks disk usage
func (fi *FaultInjector) checkDiskHealth() bool {
	// Simplified disk health check
	return !fi.resourceInjector.IsDiskPressureActive()
}

// collectMetrics collects system metrics during fault injection
func (fi *FaultInjector) collectMetrics(result *FaultResult) {
	// Collect basic system metrics
	result.MetricsCollected["timestamp"] = float64(time.Now().Unix())
	
	// In a real implementation, you would collect actual metrics
	// For now, we'll simulate some basic metrics
	result.MetricsCollected["cpu_usage"] = rand.Float64() * 100
	result.MetricsCollected["memory_usage"] = rand.Float64() * 100
	result.MetricsCollected["disk_usage"] = rand.Float64() * 100
	result.MetricsCollected["network_latency"] = rand.Float64() * 1000
}

// GetActiveFaults returns currently active faults
func (fi *FaultInjector) GetActiveFaults() map[string]*ActiveFault {
	fi.faultMutex.RLock()
	defer fi.faultMutex.RUnlock()
	
	faults := make(map[string]*ActiveFault)
	for id, fault := range fi.activeFaults {
		faults[id] = fault
	}
	return faults
}

// StopAllFaults stops all active fault injections
func (fi *FaultInjector) StopAllFaults() error {
	fi.faultMutex.Lock()
	defer fi.faultMutex.Unlock()

	var errors []string
	for faultID := range fi.activeFaults {
		if err := fi.stopFault(faultID); err != nil {
			errors = append(errors, err.Error())
		}
	}

	if len(errors) > 0 {
		return fmt.Errorf("failed to stop some faults: %s", fmt.Sprintf("%v", errors))
	}

	return nil
}

// DatabaseFaultInjector handles database-specific fault injection
type DatabaseFaultInjector struct {
	failureActive bool
	failureRate   float64
	mutex         sync.RWMutex
}

// NewDatabaseFaultInjector creates a new database fault injector
func NewDatabaseFaultInjector() *DatabaseFaultInjector {
	return &DatabaseFaultInjector{}
}

// InjectConnectionFailures injects database connection failures
func (dfi *DatabaseFaultInjector) InjectConnectionFailures(failureRate float64) (func() error, error) {
	dfi.mutex.Lock()
	defer dfi.mutex.Unlock()

	dfi.failureActive = true
	dfi.failureRate = failureRate

	// Return stop function
	stopFunc := func() error {
		dfi.mutex.Lock()
		defer dfi.mutex.Unlock()
		dfi.failureActive = false
		dfi.failureRate = 0
		return nil
	}

	return stopFunc, nil
}

// IsFailureActive returns true if database failures are being injected
func (dfi *DatabaseFaultInjector) IsFailureActive() bool {
	dfi.mutex.RLock()
	defer dfi.mutex.RUnlock()
	return dfi.failureActive
}

// ShouldFail returns true if a database operation should fail
func (dfi *DatabaseFaultInjector) ShouldFail() bool {
	dfi.mutex.RLock()
	defer dfi.mutex.RUnlock()
	
	if !dfi.failureActive {
		return false
	}
	
	return rand.Float64() < dfi.failureRate
}