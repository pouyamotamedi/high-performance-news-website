package testing

import (
	"context"
	"fmt"
	"math/rand"
	"sync"
	"time"
)

// FaultInjector provides chaos engineering capabilities for testing system resilience
type FaultInjector struct {
	config           *ChaosConfig
	activeFaults     map[string]*ActiveFault
	faultMutex       sync.RWMutex
	networkInjector  *EnhancedNetworkInjector
	databaseInjector *EnhancedDatabaseInjector
	cacheInjector    *EnhancedCacheInjector
	resourceInjector *EnhancedResourceInjector
	idCounter        int64
	idMutex          sync.Mutex
}

// ChaosConfig configures chaos engineering parameters
type ChaosConfig struct {
	MaxConcurrentFaults int           `json:"max_concurrent_faults"`
	DefaultDuration     time.Duration `json:"default_duration"`
	SafetyLimits        SafetyLimits  `json:"safety_limits"`
	EnabledFaultTypes   []string      `json:"enabled_fault_types"`
}

// SafetyLimits defines safety boundaries for chaos testing
type SafetyLimits struct {
	MaxMemoryPressure    float64 `json:"max_memory_pressure"`     // 0.8 = 80% max memory usage
	MaxDiskPressure      float64 `json:"max_disk_pressure"`       // 0.9 = 90% max disk usage
	MaxNetworkLatency    int     `json:"max_network_latency_ms"`  // Maximum network latency in ms
	MaxFailureRate       float64 `json:"max_failure_rate"`        // 0.5 = 50% max failure rate
	MinRecoveryTime      int     `json:"min_recovery_time_ms"`    // Minimum time between faults
}

// FaultType represents different types of faults that can be injected
type FaultType string

const (
	FaultTypeDatabase      FaultType = "database"
	FaultTypeCache         FaultType = "cache"
	FaultTypeNetwork       FaultType = "network"
	FaultTypeMemory        FaultType = "memory"
	FaultTypeDisk          FaultType = "disk"
	FaultTypeLatency       FaultType = "latency"
	FaultTypePartition     FaultType = "partition"
)

// ActiveFault represents an active fault injection
type ActiveFault struct {
	ID          string        `json:"id"`
	Type        FaultType     `json:"type"`
	Description string        `json:"description"`
	StartTime   time.Time     `json:"start_time"`
	Duration    time.Duration `json:"duration"`
	Parameters  map[string]interface{} `json:"parameters"`
	StopFunc    func() error  `json:"-"`
}

// FaultResult represents the result of a fault injection test
type FaultResult struct {
	FaultID           string        `json:"fault_id"`
	Type              FaultType     `json:"type"`
	Duration          time.Duration `json:"duration"`
	SystemRecovered   bool          `json:"system_recovered"`
	RecoveryTime      time.Duration `json:"recovery_time"`
	ErrorsObserved    []string      `json:"errors_observed"`
	MetricsCollected  map[string]float64 `json:"metrics_collected"`
	GracefulDegradation bool        `json:"graceful_degradation"`
	Parameters        map[string]interface{} `json:"parameters"`
}

// NewFaultInjector creates a new fault injector with default configuration
func NewFaultInjector() *FaultInjector {
	config := &ChaosConfig{
		MaxConcurrentFaults: 3,
		DefaultDuration:     30 * time.Second,
		SafetyLimits: SafetyLimits{
			MaxMemoryPressure: 0.8,
			MaxDiskPressure:   0.9,
			MaxNetworkLatency: 5000,
			MaxFailureRate:    0.5,
			MinRecoveryTime:   1000,
		},
		EnabledFaultTypes: []string{
			string(FaultTypeDatabase),
			string(FaultTypeCache),
			string(FaultTypeNetwork),
			string(FaultTypeMemory),
			string(FaultTypeDisk),
		},
	}

	return &FaultInjector{
		config:           config,
		activeFaults:     make(map[string]*ActiveFault),
		networkInjector:  NewEnhancedNetworkInjector(),
		databaseInjector: NewEnhancedDatabaseInjector(),
		cacheInjector:    NewEnhancedCacheInjector(),
		resourceInjector: NewEnhancedResourceInjector(),
		idCounter:        0,
	}
}

// generateUniqueID generates a unique ID for faults
func (fi *FaultInjector) generateUniqueID(prefix string) string {
	fi.idMutex.Lock()
	defer fi.idMutex.Unlock()
	fi.idCounter++
	return fmt.Sprintf("%s_%d_%d", prefix, time.Now().UnixNano(), fi.idCounter)
}

// InjectDatabaseFailure simulates database connection failures
func (fi *FaultInjector) InjectDatabaseFailure(ctx context.Context, failureRate float64, duration time.Duration) (*FaultResult, error) {
	if failureRate > fi.config.SafetyLimits.MaxFailureRate {
		return nil, fmt.Errorf("failure rate %.2f exceeds safety limit %.2f", failureRate, fi.config.SafetyLimits.MaxFailureRate)
	}

	faultID := fi.generateUniqueID("db_failure")
	
	fault := &ActiveFault{
		ID:          faultID,
		Type:        FaultTypeDatabase,
		Description: fmt.Sprintf("Database failure injection with %.2f failure rate", failureRate),
		StartTime:   time.Now(),
		Duration:    duration,
		Parameters: map[string]interface{}{
			"failure_rate": failureRate,
		},
	}

	// Start database fault injection
	stopFunc, err := fi.databaseInjector.InjectConnectionFailures(failureRate)
	if err != nil {
		return nil, fmt.Errorf("failed to inject database failures: %w", err)
	}
	fault.StopFunc = stopFunc

	fi.registerActiveFault(fault)

	// Monitor system behavior during fault
	result := fi.monitorFaultImpact(ctx, fault)

	// Stop fault injection
	if err := fi.stopFault(faultID); err != nil {
		result.ErrorsObserved = append(result.ErrorsObserved, fmt.Sprintf("Failed to stop fault: %v", err))
	}

	return result, nil
}

// InjectCacheFailure simulates cache service failures
func (fi *FaultInjector) InjectCacheFailure(ctx context.Context, failureType string, duration time.Duration) (*FaultResult, error) {
	faultID := fi.generateUniqueID("cache_failure")
	
	fault := &ActiveFault{
		ID:          faultID,
		Type:        FaultTypeCache,
		Description: fmt.Sprintf("Cache failure injection: %s", failureType),
		StartTime:   time.Now(),
		Duration:    duration,
		Parameters: map[string]interface{}{
			"failure_type": failureType,
		},
	}

	// Start cache fault injection
	stopFunc, err := fi.cacheInjector.InjectFailure(failureType)
	if err != nil {
		return nil, fmt.Errorf("failed to inject cache failures: %w", err)
	}
	fault.StopFunc = stopFunc

	fi.registerActiveFault(fault)

	// Monitor system behavior during fault
	result := fi.monitorFaultImpact(ctx, fault)

	// Stop fault injection
	if err := fi.stopFault(faultID); err != nil {
		result.ErrorsObserved = append(result.ErrorsObserved, fmt.Sprintf("Failed to stop fault: %v", err))
	}

	return result, nil
}

// InjectNetworkPartition simulates network partitions and latency
func (fi *FaultInjector) InjectNetworkPartition(ctx context.Context, latencyMs int, packetLoss float64, duration time.Duration) (*FaultResult, error) {
	if latencyMs > fi.config.SafetyLimits.MaxNetworkLatency {
		return nil, fmt.Errorf("latency %dms exceeds safety limit %dms", latencyMs, fi.config.SafetyLimits.MaxNetworkLatency)
	}

	faultID := fmt.Sprintf("network_partition_%d", time.Now().UnixNano())
	
	fault := &ActiveFault{
		ID:          faultID,
		Type:        FaultTypeNetwork,
		Description: fmt.Sprintf("Network partition with %dms latency and %.2f packet loss", latencyMs, packetLoss),
		StartTime:   time.Now(),
		Duration:    duration,
		Parameters: map[string]interface{}{
			"latency_ms":   latencyMs,
			"packet_loss": packetLoss,
		},
	}

	// Start network fault injection
	stopFunc, err := fi.networkInjector.InjectLatencyAndLoss(latencyMs, packetLoss)
	if err != nil {
		return nil, fmt.Errorf("failed to inject network faults: %w", err)
	}
	fault.StopFunc = stopFunc

	fi.registerActiveFault(fault)

	// Monitor system behavior during fault
	result := fi.monitorFaultImpact(ctx, fault)

	// Stop fault injection
	if err := fi.stopFault(faultID); err != nil {
		result.ErrorsObserved = append(result.ErrorsObserved, fmt.Sprintf("Failed to stop fault: %v", err))
	}

	return result, nil
}

