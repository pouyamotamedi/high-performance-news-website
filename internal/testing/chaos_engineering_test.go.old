	"time"

	"github.com/stretchr/testify/assert"
	"github.com/stretchr/testify/require"
)

func TestFaultInjector_DatabaseFailure(t *testing.T) {
	injector := NewFaultInjector()
	ctx := context.Background()

	t.Run("successful database failure injection", func(t *testing.T) {
		result, err := injector.InjectDatabaseFailure(ctx, 0.5, 5*time.Second)
		
		require.NoError(t, err)
		assert.NotNil(t, result)
		assert.Equal(t, FaultTypeDatabase, result.Type)
		assert.True(t, result.Duration >= 5*time.Second)
		assert.Contains(t, result.FaultID, "db_failure_")
	})

	t.Run("failure rate exceeds safety limit", func(t *testing.T) {
		result, err := injector.InjectDatabaseFailure(ctx, 0.9, 5*time.Second)
		
		assert.Error(t, err)
		assert.Nil(t, result)
		assert.Contains(t, err.Error(), "exceeds safety limit")
	})

	t.Run("multiple concurrent database failures", func(t *testing.T) {
		// Start faults in goroutines so we can check active faults while they're running
		var wg sync.WaitGroup
		var result1, result2 *FaultResult
		var err1, err2 error
		
		wg.Add(2)
		
		go func() {
			defer wg.Done()
			result1, err1 = injector.InjectDatabaseFailure(ctx, 0.3, 2*time.Second)
		}()
		
		go func() {
			defer wg.Done()
			result2, err2 = injector.InjectDatabaseFailure(ctx, 0.2, 2*time.Second)
		}()
		
		// Wait a moment for faults to start
		time.Sleep(100 * time.Millisecond)
		
		// Check active faults while they're running
		activeFaults := injector.GetActiveFaults()
		assert.GreaterOrEqual(t, len(activeFaults), 1) // At least one should be active
		
		// Wait for completion
		wg.Wait()
		
		require.NoError(t, err1)
		require.NoError(t, err2)
		require.NotNil(t, result1)
		require.NotNil(t, result2)
		assert.NotEqual(t, result1.FaultID, result2.FaultID)
	})
}

func TestFaultInjector_CacheFailure(t *testing.T) {
	injector := NewFaultInjector()
	ctx := context.Background()

	t.Run("timeout failure injection", func(t *testing.T) {
		result, err := injector.InjectCacheFailure(ctx, "timeout", 5*time.Second)
		
		require.NoError(t, err)
		assert.NotNil(t, result)
		assert.Equal(t, FaultTypeCache, result.Type)
		assert.Contains(t, result.FaultID, "cache_failure_")
	})

	t.Run("connection error injection", func(t *testing.T) {
		result, err := injector.InjectCacheFailure(ctx, "connection_error", 3*time.Second)
		
		require.NoError(t, err)
		assert.NotNil(t, result)
		assert.Equal(t, "connection_error", result.Parameters["failure_type"])
	})

	t.Run("data corruption injection", func(t *testing.T) {
		result, err := injector.InjectCacheFailure(ctx, "data_corruption", 4*time.Second)
		
		require.NoError(t, err)
		assert.NotNil(t, result)
		assert.Equal(t, "data_corruption", result.Parameters["failure_type"])
	})
}

func TestFaultInjector_NetworkPartition(t *testing.T) {
	injector := NewFaultInjector()
	ctx := context.Background()

	t.Run("successful network partition injection", func(t *testing.T) {
		result, err := injector.InjectNetworkPartition(ctx, 500, 0.1, 5*time.Second)
		
		require.NoError(t, err)
		assert.NotNil(t, result)
		assert.Equal(t, FaultTypeNetwork, result.Type)
		assert.Equal(t, 500, result.Parameters["latency_ms"])
		assert.Equal(t, 0.1, result.Parameters["packet_loss"])
	})

	t.Run("latency exceeds safety limit", func(t *testing.T) {
		result, err := injector.InjectNetworkPartition(ctx, 10000, 0.1, 5*time.Second)
		
		assert.Error(t, err)
		assert.Nil(t, result)
		assert.Contains(t, err.Error(), "exceeds safety limit")
	})

	t.Run("high packet loss injection", func(t *testing.T) {
		result, err := injector.InjectNetworkPartition(ctx, 200, 0.5, 3*time.Second)
		
		require.NoError(t, err)
		assert.Equal(t, 0.5, result.Parameters["packet_loss"])
	})
}

