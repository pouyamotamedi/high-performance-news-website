		"PageType": "homepage",
		"Articles": []gin.H{
			{"Title": "Sample News Article", "Slug": "sample-1", "Category": "Technology", "Author": "Admin User", "TimeAgo": "2 hours ago"},
			{"Title": "Another Sample Article", "Slug": "sample-2", "Category": "Business", "Author": "Editor", "TimeAgo": "4 hours ago"},
			{"Title": "Sports News Sample", "Slug": "sample-3", "Category": "Sports", "Author": "Sports Reporter", "TimeAgo": "6 hours ago"},
		},
		"Categories": []gin.H{
			{"Name": "Technology", "Slug": "technology", "Description": "Latest tech news and innovations", "Count": 0},
			{"Name": "Business", "Slug": "business", "Description": "Business and financial news", "Count": 0},
			{"Name": "Sports", "Slug": "sports", "Description": "Sports news and updates", "Count": 0},
			{"Name": "World", "Slug": "world", "Description": "International news coverage", "Count": 0},
		},
	})
}

// Content generation functions for fallback rendering

func (s *Server) generateHomepageContent(data gin.H) string {
	content := `<div class="container">
        <section class="hero">
            <h1>Welcome to ` + s.config.App.Name + `</h1>
            <p>Your source for fast, reliable news content with cutting-edge performance</p>
        </section>`
	
	if articles, ok := data["Articles"].([]gin.H); ok && len(articles) > 0 {
		content += `<section><h2>Latest Articles</h2><div class="articles-grid">`
		for _, article := range articles {
			title := fmt.Sprintf("%v", article["Title"])
			slug := fmt.Sprintf("%v", article["Slug"])
			category := fmt.Sprintf("%v", article["Category"])
			author := fmt.Sprintf("%v", article["Author"])
			timeAgo := fmt.Sprintf("%v", article["TimeAgo"])
			
			content += fmt.Sprintf(`
                <article class="article-card">
                    <h3><a href="/articles/%s">%s</a></h3>
                    <div class="article-meta">
                        <span>%s</span> • <span>%s</span> • <span>%s</span>
                    </div>
                </article>`, slug, title, category, author, timeAgo)
		}
		content += `</div></section>`
	}
	
	if categories, ok := data["Categories"].([]gin.H); ok && len(categories) > 0 {
		content += `<section><h2>Categories</h2><div class="categories-grid">`
		for _, category := range categories {
			name := fmt.Sprintf("%v", category["Name"])
			slug := fmt.Sprintf("%v", category["Slug"])
			description := fmt.Sprintf("%v", category["Description"])
			
			content += fmt.Sprintf(`
                <div class="category-card">
                    <h4><a href="/categories/%s">%s</a></h4>
                    <p>%s</p>
                </div>`, slug, name, description)
		}
		content += `</div></section>`
	}
	
	content += `</div>`
	return content
}

func (s *Server) generateArticleContent(data gin.H) string {
	title := "Sample Article"
	content := "This is a sample article content."
	
	if article, ok := data["Article"].(gin.H); ok {
		if t, exists := article["Title"]; exists {
			title = fmt.Sprintf("%v", t)
		}
		if c, exists := article["Content"]; exists {
			content = fmt.Sprintf("%v", c)
		}
	}
	
	return fmt.Sprintf(`<div class="container">
        <article>
            <header>
                <h1>%s</h1>
            </header>
            <div class="article-content">
                %s
            </div>
        </article>
    </div>`, title, content)
}

func (s *Server) generateCategoryContent(data gin.H) string {
	title := fmt.Sprintf("%v", data["Title"])
	description := fmt.Sprintf("%v", data["Description"])
	
	return fmt.Sprintf(`<div class="container">
        <header>
            <h1>%s</h1>
            <p>%s</p>
        </header>
        <div class="content">
            <p>Articles in this category will be displayed here.</p>
        </div>
    </div>`, title, description)
}

func (s *Server) generateTagContent(data gin.H) string {
	title := fmt.Sprintf("%v", data["Title"])
	description := fmt.Sprintf("%v", data["Description"])
	
	return fmt.Sprintf(`<div class="container">
        <header>
            <h1>%s</h1>
            <p>%s</p>
        </header>
        <div class="content">
            <p>Articles with this tag will be displayed here.</p>
        </div>
    </div>`, title, description)
}

func (s *Server) generateGenericContent(data gin.H) string {
	title := fmt.Sprintf("%v", data["Title"])
	content := fmt.Sprintf("%v", data["Content"])
	if content == "" || content == "<nil>" {
		content = "This page is under construction."
	}
	
	return fmt.Sprintf(`<div class="container">
        <header>
            <h1>%s</h1>
        </header>
        <div class="content">
            <p>%s</p>
        </div>
    </div>`, title, content)
}

