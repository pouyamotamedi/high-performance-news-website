# Comprehensive Testing & QA System - Integration Configuration Example

# Integration Manager Configuration
integration_manager:
  # Enable/disable the integration system
  enabled: true
  
  # Default timeout for integration operations
  default_timeout: "30s"
  
  # Maximum concurrent integrations
  max_concurrent: 10

# Built-in Integrations Configuration
integrations:
  # JIRA Bug Tracking Integration
  jira:
    enabled: true
    type: "bug_tracking"
    settings:
      base_url: "https://your-company.atlassian.net"
      username: "your-email@company.com"
      api_token: "${JIRA_API_TOKEN}"
      project_key: "QA"
    fallbacks: ["github", "slack"]
    
  # GitHub Code Review Integration
  github:
    enabled: true
    type: "code_review"
    settings:
      token: "${GITHUB_TOKEN}"
      owner: "your-org"
      repo: "news-website"
      base_url: "https://api.github.com"
    fallbacks: ["slack"]
    
  # Prometheus Monitoring Integration
  prometheus:
    enabled: true
    type: "monitoring"
    settings:
      push_gateway_url: "http://localhost:9091"
      job_name: "comprehensive_testing_qa"
      instance: "localhost"
    fallbacks: ["slack"]
    
  # Slack Communication Integration
  slack:
    enabled: true
    type: "communication"
    settings:
      webhook_url: "${SLACK_WEBHOOK_URL}"
      channel: "#qa-alerts"
      username: "QA Bot"
    fallbacks: []

# Webhook Configuration
webhooks:
  # External CI/CD webhook
  ci_cd_webhook:
    name: "ci_cd_integration"
    url: "https://your-ci-system.com/webhook"
    secret: "${WEBHOOK_SECRET}"
    enabled: true
    events: ["test_failure", "test_success", "deployment"]
    retries: 3
    timeout: "10s"
    headers:
      "Content-Type": "application/json"
      "X-Source": "comprehensive-testing-qa"
      
  # Project management webhook
  project_mgmt_webhook:
    name: "project_management"
    url: "https://your-pm-tool.com/api/webhook"
    enabled: true
    events: ["test_failure", "security_alert"]
    retries: 2
    timeout: "15s"

# Plugin Configuration
plugins:
  # Enable plugin system
  enabled: true
  
  # Plugin directory
  plugin_directory: "./plugins"
  
  # Auto-load plugins on startup
  auto_load: true
  
  # Plugin configurations
  custom_integrations:
    - name: "custom_bug_tracker"
      path: "./plugins/custom_bug_tracker.so"
      enabled: true
      auto_load: true
      settings:
        api_url: "https://custom-tracker.com/api"
        api_key: "${CUSTOM_TRACKER_API_KEY}"
      permissions: ["send_events", "create_issues"]

# Workflow Automation Configuration
workflows:
  # Critical test failure workflow
  critical_test_failure:
    name: "Critical Test Failure Response"
    description: "Automated response to critical test failures"
    enabled: true
    triggers:
      - type: "event"
        event_type: "test_failure"
        conditions:
          priority: "critical"
    actions:
      - type: "create_issue"
        integration: "jira"
        template: |
          Critical test failure detected:
          Test: {{event.data.test_name}}
          Error: {{event.data.error}}
          Commit: {{event.data.commit_sha}}
        parameters:
          priority: "highest"
          labels: ["critical", "automated", "test-failure"]
        timeout: "30s"
        retries: 2
      - type: "send_message"
        integration: "slack"
        template: |
          🚨 CRITICAL TEST FAILURE 🚨
          Test: {{event.data.test_name}}
          Branch: {{event.data.branch}}
          Please investigate immediately!
        timeout: "10s"
        retries: 1
    config:
      max_concurrent_executions: 1
      execution_timeout: "5m"
      retry_policy:
        max_retries: 3
        initial_delay: "1s"
        max_delay: "30s"
        backoff_multiplier: 2.0
      notification_settings:
        on_success: false
        on_failure: true
        channels: ["slack"]

  # Security alert workflow
  security_alert_response:
    name: "Security Alert Response"
    description: "Automated response to security alerts"
    enabled: true
    triggers:
      - type: "event"
        event_type: "security_alert"
    actions:
      - type: "create_issue"
        integration: "jira"
        template: |
          Security vulnerability detected:
          Type: {{event.data.vulnerability_type}}
          Severity: {{event.data.severity}}
          File: {{event.data.file}}
          Description: {{event.data.description}}
        parameters:
          issue_type: "Security Issue"
          priority: "high"
        timeout: "30s"
      - type: "http_request"
        parameters:
          url: "https://security-scanner.company.com/api/alerts"
          method: "POST"
          headers:
            "Authorization": "Bearer ${SECURITY_API_TOKEN}"
            "Content-Type": "application/json"
          body: |
            {
              "alert_type": "{{event.type}}",
              "severity": "{{event.data.severity}}",
              "source": "comprehensive-testing-qa",
              "details": {{event.data}}
            }
        timeout: "15s"

# Failover Configuration
failover:
  # Circuit breaker settings
  circuit_breaker:
    failure_threshold: 5
    recovery_timeout: "30s"
    
  # Retry policies
  retry_policies:
    default:
      max_retries: 3
      initial_delay: "1s"
      max_delay: "30s"
      backoff_multiplier: 2.0
      retryable_errors: ["timeout", "connection_error", "temporary_failure"]
    
    critical:
      max_retries: 5
      initial_delay: "500ms"
      max_delay: "10s"
      backoff_multiplier: 1.5
      retryable_errors: ["timeout", "connection_error", "temporary_failure", "rate_limit"]

# API Configuration
api:
  # REST API settings
  rest:
    enabled: true
    port: 8081
    path_prefix: "/api/v1/integrations"
    
  # GraphQL API settings
  graphql:
    enabled: true
    endpoint: "/graphql"
    playground: true # Enable GraphQL playground in development
    
  # Authentication (if required)
  auth:
    enabled: false
    type: "bearer_token"
    token: "${API_AUTH_TOKEN}"

# Monitoring and Observability
monitoring:
  # Enable metrics collection
  metrics_enabled: true
  
  # Metrics export interval
  metrics_interval: "30s"
  
  # Health check interval
  health_check_interval: "60s"
  
  # Log level for integration system
  log_level: "info"
  
  # Enable detailed request/response logging
  detailed_logging: false

# Environment-specific overrides
environments:
  development:
    integration_manager:
      default_timeout: "10s"
    api:
      graphql:
        playground: true
    monitoring:
      log_level: "debug"
      detailed_logging: true
      
  production:
    integration_manager:
      default_timeout: "30s"
    api:
      graphql:
        playground: false
    monitoring:
      log_level: "warn"
      detailed_logging: false
    failover:
      circuit_breaker:
        failure_threshold: 3
        recovery_timeout: "60s"