-- Content Sources table
CREATE TABLE content_sources (
    id BIGSERIAL PRIMARY KEY,
    name VARCHAR(100) NOT NULL,
    type VARCHAR(20) NOT NULL CHECK (type IN ('api', 'webhook', 'manual')),
    api_key VARCHAR(255) UNIQUE NOT NULL,
    is_active BOOLEAN DEFAULT true,
    rate_limit INTEGER DEFAULT 100 CHECK (rate_limit >= 0 AND rate_limit <= 10000),
    priority INTEGER DEFAULT 5 CHECK (priority >= 1 AND priority <= 10),
    config JSONB NOT NULL DEFAULT '{}',
    created_at TIMESTAMP WITH TIME ZONE DEFAULT NOW(),
    updated_at TIMESTAMP WITH TIME ZONE DEFAULT NOW()
);

-- Indexes for content_sources
CREATE INDEX idx_content_sources_api_key ON content_sources (api_key) WHERE is_active = true;
CREATE INDEX idx_content_sources_type ON content_sources (type);
CREATE INDEX idx_content_sources_priority ON content_sources (priority DESC);

-- Ingested Content table (partitioned by created_at for high volume)
CREATE TABLE ingested_content (
    id BIGSERIAL,
    source_id BIGINT NOT NULL REFERENCES content_sources(id),
    external_id VARCHAR(255) NOT NULL,
    title VARCHAR(255) NOT NULL,
    content TEXT NOT NULL,
    excerpt TEXT,
    author_name VARCHAR(100),
    author_email VARCHAR(255),
    category_name VARCHAR(100),
    tags JSONB DEFAULT '[]',
    published_at TIMESTAMP WITH TIME ZONE,
    source_url VARCHAR(500),
    content_hash VARCHAR(64) NOT NULL,
    status VARCHAR(20) DEFAULT 'pending' CHECK (status IN ('pending', 'processed', 'rejected', 'duplicate')),
    processed_at TIMESTAMP WITH TIME ZONE,
    article_id BIGINT, -- References articles(id) but no FK constraint due to partitioning
    rejection_reason TEXT,
    metadata JSONB DEFAULT '{}',
    created_at TIMESTAMP WITH TIME ZONE DEFAULT NOW(),
    updated_at TIMESTAMP WITH TIME ZONE DEFAULT NOW(),
    PRIMARY KEY (id, created_at)
) PARTITION BY RANGE (created_at);

-- Create initial partition for ingested_content (current month)
CREATE TABLE ingested_content_2024_01 PARTITION OF ingested_content
FOR VALUES FROM ('2024-01-01') TO ('2024-02-01');

-- Indexes for ingested_content
CREATE INDEX idx_ingested_content_source_external ON ingested_content (source_id, external_id);
CREATE INDEX idx_ingested_content_hash ON ingested_content (content_hash);
CREATE INDEX idx_ingested_content_status ON ingested_content (status, created_at DESC);
CREATE INDEX idx_ingested_content_source_url ON ingested_content (source_url) WHERE source_url IS NOT NULL;
CREATE INDEX idx_ingested_content_article ON ingested_content (article_id) WHERE article_id IS NOT NULL;

-- BRIN index for time-series data on ingested_content
CREATE INDEX idx_ingested_content_created_brin ON ingested_content 
USING BRIN (created_at) WITH (pages_per_range = 128);

-- Enable pg_trgm extension for similarity matching (if not already enabled)
CREATE EXTENSION IF NOT EXISTS pg_trgm;

-- GIN index for title similarity matching
CREATE INDEX idx_ingested_content_title_trgm ON ingested_content 
USING gin (title gin_trgm_ops);

-- Content Ingestion Rate Limiting table (for tracking API usage)
CREATE TABLE content_ingestion_rate_limits (
    id BIGSERIAL PRIMARY KEY,
    source_id BIGINT NOT NULL REFERENCES content_sources(id),
    time_window TIMESTAMP WITH TIME ZONE NOT NULL,
    request_count INTEGER DEFAULT 1,
    created_at TIMESTAMP WITH TIME ZONE DEFAULT NOW(),
    updated_at TIMESTAMP WITH TIME ZONE DEFAULT NOW(),
    UNIQUE(source_id, time_window)
);

-- Index for rate limiting lookups
CREATE INDEX idx_rate_limits_source_window ON content_ingestion_rate_limits (source_id, time_window);

-- Index for rate limit cleanup (without time predicate)
CREATE INDEX idx_rate_limits_cleanup ON content_ingestion_rate_limits (created_at);

-- Function to automatically create monthly partitions for ingested_content
CREATE OR REPLACE FUNCTION create_monthly_ingested_content_partition(partition_date DATE)
RETURNS VOID AS $$
DECLARE
    partition_name TEXT;
    start_date DATE;
    end_date DATE;
BEGIN
    -- Calculate partition boundaries
    start_date := DATE_TRUNC('month', partition_date);
    end_date := start_date + INTERVAL '1 month';
    
    -- Generate partition name
    partition_name := 'ingested_content_' || TO_CHAR(start_date, 'YYYY_MM');
    
    -- Create partition if it doesn't exist
    EXECUTE format('CREATE TABLE IF NOT EXISTS %I PARTITION OF ingested_content
                    FOR VALUES FROM (%L) TO (%L)',
                   partition_name, start_date, end_date);
    
    -- Create indexes on the new partition
    EXECUTE format('CREATE INDEX IF NOT EXISTS %I ON %I (source_id, external_id)',
                   partition_name || '_source_external', partition_name);
    EXECUTE format('CREATE INDEX IF NOT EXISTS %I ON %I (content_hash)',
                   partition_name || '_hash', partition_name);
    EXECUTE format('CREATE INDEX IF NOT EXISTS %I ON %I (status, created_at DESC)',
                   partition_name || '_status', partition_name);
END;
$$ LANGUAGE plpgsql;

-- Create partitions for the next 12 months
SELECT create_monthly_ingested_content_partition(CURRENT_DATE + (n || ' months')::INTERVAL)
FROM generate_series(0, 11) AS n;

-- Function to clean up old ingested content partitions
CREATE OR REPLACE FUNCTION cleanup_old_ingested_content_partitions(retention_months INTEGER DEFAULT 6)
RETURNS VOID AS $$
DECLARE
    partition_record RECORD;
    cutoff_date DATE;
BEGIN
    cutoff_date := CURRENT_DATE - (retention_months || ' months')::INTERVAL;
    
    FOR partition_record IN
        SELECT schemaname, tablename
        FROM pg_tables
        WHERE tablename LIKE 'ingested_content_____'
        AND tablename < 'ingested_content_' || TO_CHAR(cutoff_date, 'YYYY_MM')
    LOOP
        EXECUTE format('DROP TABLE IF EXISTS %I.%I CASCADE',
                      partition_record.schemaname, partition_record.tablename);
    END LOOP;
END;
$$ LANGUAGE plpgsql;

-- Add trigger to update updated_at timestamp
CREATE OR REPLACE FUNCTION update_updated_at_column()
RETURNS TRIGGER AS $$
BEGIN
    NEW.updated_at = NOW();
    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER update_content_sources_updated_at
    BEFORE UPDATE ON content_sources
    FOR EACH ROW
    EXECUTE FUNCTION update_updated_at_column();

CREATE TRIGGER update_ingested_content_updated_at
    BEFORE UPDATE ON ingested_content
    FOR EACH ROW
    EXECUTE FUNCTION update_updated_at_column();

-- Insert default content source for testing
INSERT INTO content_sources (name, type, api_key, is_active, rate_limit, priority, config)
VALUES (
    'Default API Source',
    'api',
    'ci_default_' || EXTRACT(EPOCH FROM NOW())::BIGINT,
    true,
    100,
    5,
    '{"auto_publish": false, "default_category_id": 1, "default_author_id": 1}'::JSONB
);

-- Comments for documentation
COMMENT ON TABLE content_sources IS 'External content sources for automated ingestion';
COMMENT ON TABLE ingested_content IS 'Content received from external sources, partitioned by created_at';
COMMENT ON TABLE content_ingestion_rate_limits IS 'Rate limiting tracking for content ingestion APIs';

COMMENT ON COLUMN content_sources.type IS 'Source type: api, webhook, or manual';
COMMENT ON COLUMN content_sources.rate_limit IS 'Maximum requests per minute (0 = unlimited)';
COMMENT ON COLUMN content_sources.priority IS 'Processing priority (1-10, higher = more important)';
COMMENT ON COLUMN content_sources.config IS 'Source-specific configuration (auto_publish, default_category_id, etc.)';

COMMENT ON COLUMN ingested_content.status IS 'Processing status: pending, processed, rejected, duplicate';
COMMENT ON COLUMN ingested_content.content_hash IS 'SHA-256 hash of title + content for duplicate detection';
COMMENT ON COLUMN ingested_content.external_id IS 'Unique identifier from the external source';
COMMENT ON COLUMN ingested_content.metadata IS 'Additional metadata from the external source';